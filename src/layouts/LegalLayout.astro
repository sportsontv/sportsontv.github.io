---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  lastUpdated?: string;
}

const { title, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={`${title} for SportsOnTV`}>
  <Header slot="header" />

  <article class="legal-page">
    <div class="container">
      <h1>{title}</h1>
      {lastUpdated && <p class="last-updated">Last updated: {lastUpdated}</p>}
      <div class="content">
        <slot />
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .legal-page {
    padding: 4rem 0;
  }

  .legal-page h1 {
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    font-size: 2.5rem;
  }

  .last-updated {
    color: var(--color-gray-500);
    margin-bottom: 2rem;
    font-size: 0.875rem;
  }

  .content {
    max-width: 800px;
  }

  .content :global(h2) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
    color: var(--color-gray-900);
  }

  .content :global(p) {
    margin-bottom: 1rem;
    color: var(--color-gray-700);
  }

  .content :global(ul) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    color: var(--color-gray-700);
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }

  .content :global(a) {
    color: var(--color-primary);
  }

  .content :global(a:hover) {
    text-decoration: underline;
  }
</style>
